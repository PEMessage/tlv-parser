#!/usr/bin/env python3
"""TLV heuristic parser — xxd-style output with ANSI color highlighting.

Reads a byte stream from stdin, finds all valid TLV structures, and renders
them with colored backgrounds in xxd format.

TLV format:
    TAG (2B): B0 in [0x00, 0x10], B1 in {'I','O'}
    LEN (2B): little-endian value length
    VALUE (nB)
"""

import sys
import os
import re
import argparse
import termios
import select
from dataclasses import dataclass

_RESET = "\033[0m"

# _BaseRed = (246, 88, 102)
# _BaseYel = (239, 189, 93)
# _BaseBlu = (65, 156, 255)
_BaseRed = (255, 0, 0)
_BaseYel = (255, 255, 0)
_BaseBlu = (0, 0, 255)
_Alpha = 0.2
_DefaultBG = (255, 255, 255)

# Color = ("true", R, G, B) | ("ansi", N) | None
#   "true"  — truecolor RGB
#   "ansi"  — traditional ANSI/256 palette index
#   None    — default terminal color

_CACHED_BG: tuple[int, int, int] | None = None
_CACHED_TAG_BG: tuple | None = None
_CACHED_LEN_BG: tuple | None = None
_CACHED_VAL_BG: tuple | None = None


def _bg_color() -> tuple[int, int, int]:
    global _CACHED_BG
    if _CACHED_BG is not None:
        return _CACHED_BG
    _CACHED_BG = _query_bg() or _DefaultBG
    return _CACHED_BG


def _query_bg() -> tuple[int, int, int] | None:
    try:
        fd = os.open("/dev/tty", os.O_RDWR)
    except OSError:
        return None
    try:
        old = termios.tcgetattr(fd)
        new = termios.tcgetattr(fd)
        new[3] &= ~(termios.ICANON | termios.ECHO)
        new[6][termios.VMIN] = 1
        new[6][termios.VTIME] = 3
        termios.tcsetattr(fd, termios.TCSANOW, new)
        os.write(fd, b"\x1b]11;?\x1b\\")
        buf = b""
        while True:
            r, _, _ = select.select([fd], [], [], 0.3)
            if not r:
                break
            try:
                ch = os.read(fd, 1)
            except OSError:
                break
            if not ch:
                break
            buf += ch
            if buf.endswith(b"\x1b\\") or buf.endswith(b"\x07"):
                break
        termios.tcsetattr(fd, termios.TCSANOW, old)
        os.close(fd)
        return _parse_osc11(buf)
    except Exception:
        try:
            termios.tcsetattr(fd, termios.TCSANOW, old)
        except Exception:
            pass
        os.close(fd)
        return None


def _parse_osc11(data: bytes) -> tuple[int, int, int] | None:
    text = data.decode(errors="replace")
    m = re.search(r"rgb:([0-9a-fA-F]{1,4})/([0-9a-fA-F]{1,4})/([0-9a-fA-F]{1,4})", text)
    if m:
        return (
            int(m.group(1), 16) >> (max(len(m.group(1)) - 2, 0) * 4),
            int(m.group(2), 16) >> (max(len(m.group(2)) - 2, 0) * 4),
            int(m.group(3), 16) >> (max(len(m.group(3)) - 2, 0) * 4),
        )
    m = re.search(r"#([0-9a-fA-F]{2})([0-9a-fA-F]{2})([0-9a-fA-F]{2})", text)
    if m:
        return int(m.group(1), 16), int(m.group(2), 16), int(m.group(3), 16)
    return None


def _blend(fg_rgb: tuple[int, int, int], bg_rgb: tuple[int, int, int],
           alpha: float = _Alpha) -> tuple[int, int, int]:
    return (
        int(alpha * fg_rgb[0] + (1 - alpha) * bg_rgb[0]),
        int(alpha * fg_rgb[1] + (1 - alpha) * bg_rgb[1]),
        int(alpha * fg_rgb[2] + (1 - alpha) * bg_rgb[2]),
    )


def _tag_bg() -> tuple:
    global _CACHED_TAG_BG
    if _CACHED_TAG_BG is None:
        _CACHED_TAG_BG = ("true",) + _blend(_BaseRed, _bg_color())
    return _CACHED_TAG_BG


def _len_bg() -> tuple:
    global _CACHED_LEN_BG
    if _CACHED_LEN_BG is None:
        _CACHED_LEN_BG = ("true",) + _blend(_BaseYel, _bg_color())
    return _CACHED_LEN_BG


def _val_bg() -> tuple:
    global _CACHED_VAL_BG
    if _CACHED_VAL_BG is None:
        _CACHED_VAL_BG = ("true",) + _blend(_BaseBlu, _bg_color())
    return _CACHED_VAL_BG


def _char_color(b: int) -> tuple:
    if 32 <= b <= 126:
        return ("ansi", 32)
    if b in (9, 10, 13):
        return ("ansi", 33)
    if b == 0:
        return ("ansi", 37)
    if b == 255:
        return ("ansi", 34)
    return ("ansi", 31)


def _bg_ansi(c: tuple | None) -> str:
    if c is None:
        return "\033[49m"
    kind = c[0]
    if kind == "true":
        _, r, g, b = c
        return f"\033[48;2;{r};{g};{b}m"
    _, code = c
    return f"\033[{code + 10}m"


def _fg_ansi(c: tuple) -> str:
    kind = c[0]
    if kind == "true":
        _, r, g, b = c
        return f"\033[38;2;{r};{g};{b}m"
    _, code = c
    return f"\033[{code}m"


def _byte_ansi(offset: int, b: int,
               cmap: dict[int, tuple]) -> str:
    bg = cmap.get(offset)
    fg = _char_color(b)
    return f"\033[0m{_bg_ansi(bg)}{_fg_ansi(fg)}"


@dataclass
class TLV:
    start: int
    tag_end: int
    len_end: int
    value_end: int


def parse(data: bytes, mode: str = "overlap") -> list[TLV]:
    total = len(data)
    result: list[TLV] = []
    i = 0
    while i < max(0, total - 1):
        b0, b1 = data[i], data[i + 1]
        if 0x00 <= b0 <= 0x10 and b1 in (0x49, 0x4F):
            if i + 4 <= total:
                length = data[i + 2] | (data[i + 3] << 8)
                if i + 4 + length <= total:
                    result.append(TLV(i, i + 2, i + 4, i + 4 + length))
                    if mode == "exclude":
                        i = i + 4 + length
                        continue
        i += 1
    return result


def build_color_map(tlvs: list[TLV], total: int) -> dict[int, tuple]:
    cmap: dict[int, tuple[int, int, int]] = {}
    for t in tlvs:
        for p in range(t.start, t.tag_end):
            cmap[p] = _tag_bg()
        for p in range(t.tag_end, t.len_end):
            cmap[p] = _len_bg()
        for p in range(t.len_end, t.value_end):
            cmap[p] = _val_bg()
    return cmap


def render_xxd(data: bytes, cmap: dict[int, tuple]) -> str:
    lines: list[str] = []
    total = len(data)

    for offset in range(0, total, 16):
        chunk = data[offset:offset + 16]
        n = len(chunk)

        hex_items = []
        for j in range(16):
            if j < n:
                b = chunk[j]
                c = _byte_ansi(offset + j, b, cmap)
                h = f"{b:02x}"
                hex_items.append(f"{c}{h}")
            else:
                hex_items.append("  ")

        left = " ".join(hex_items[:8])
        right = " ".join(hex_items[8:])
        hex_line = f"{left}  {right}"

        ascii_chars = []
        for j in range(16):
            if j < n:
                b = chunk[j]
                c = _byte_ansi(offset + j, b, cmap)
                ch = chr(b) if 0x20 <= b <= 0x7E else "."
                ascii_chars.append(f"{c}{ch}")
            else:
                ascii_chars.append(" ")

        lines.append(f"{offset:08x}: {hex_line}{_RESET}  {''.join(ascii_chars)}{_RESET}")

    return "\n".join(lines)


def main() -> None:
    parser = argparse.ArgumentParser(
        description="TLV heuristic parser — xxd-style output with ANSI colors"
    )
    parser.add_argument("-m", "--mode", choices=["overlap", "exclude"],
                        default="overlap",
                        help="parse mode: overlap (default) or exclude")
    args = parser.parse_args()

    data = sys.stdin.buffer.read()
    if not data:
        return

    tlvs = parse(data, mode=args.mode)
    cmap = build_color_map(tlvs, len(data))
    print(render_xxd(data, cmap))


if __name__ == "__main__":
    main()
