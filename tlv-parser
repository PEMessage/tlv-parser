#!/usr/bin/env python3
"""TLV heuristic parser — xxd-style output with ANSI color highlighting.

Reads a byte stream from stdin, finds all valid TLV structures, and renders
them with colored backgrounds in xxd format.

TLV format:
    TAG (2B): B0 in [0x00, 0x10], B1 in {'I','O'}
    LEN (2B): little-endian value length
    VALUE (nB)
"""

from __future__ import annotations

import argparse
import os
import re
import select
import sys
import termios
from collections.abc import Callable
from dataclasses import dataclass
from enum import Enum
from functools import cache

RESET = "\033[0m"

DEFAULT_BG = (255, 255, 255)

BYTES_PER_LINE = 16
HALF_LINE = BYTES_PER_LINE // 2

TAG_B0_HI = 0x10
TAG_B1_SET = {0x49, 0x4F}  # 'I', 'O'

# ---------------------------------------------------------------------------
#  Color types — tagged unions for safe, readable colour handling
# ---------------------------------------------------------------------------

@dataclass(frozen=True)
class TrueColor:
    """24-bit RGB background / foreground."""
    r: int
    g: int
    b: int


@dataclass(frozen=True)
class AnsiColor:
    """Traditional ANSI palette / 256-color index."""
    code: int


@dataclass(frozen=True)
class AlphaColor:
    """RGBA colour that is blended against the terminal background at render time."""
    r: int
    g: int
    b: int
    a: float


Color = TrueColor | AnsiColor | AlphaColor | None
"""Possible colour states: truecolour, ANSI index, alpha-blended, or default."""


class ColorMode(Enum):
    ALL  = "all"
    FG   = "fg"
    BG   = "bg"
    NONE = "none"

    @property
    def use_bg(self) -> bool:
        return self in (ColorMode.ALL, ColorMode.BG)

    @property
    def use_fg(self) -> bool:
        return self in (ColorMode.ALL, ColorMode.FG)

# ---------------------------------------------------------------------------
#  Terminal background detection
# ---------------------------------------------------------------------------

@cache
def detect_terminal_background() -> tuple[int, int, int]:
    """Query the terminal's background colour via OSC 11; fall back to white."""
    rgb = _query_osc_11()
    return rgb if rgb is not None else DEFAULT_BG


def _query_osc_11() -> tuple[int, int, int] | None:
    try:
        fd = os.open("/dev/tty", os.O_RDWR)
    except OSError:
        return None

    try:
        old = termios.tcgetattr(fd)
        _set_raw_mode(fd)
        os.write(fd, b"\x1b]11;?\x1b\\")
        response = _read_osc_response(fd)
    except Exception:
        response = None
    finally:
        _restore_terminal(fd, old)
        os.close(fd)

    if response is None:
        return None
    return _parse_osc11_response(response)


def _set_raw_mode(fd: int) -> None:
    new = termios.tcgetattr(fd)
    new[3] &= ~(termios.ICANON | termios.ECHO)
    new[6][termios.VMIN] = 1
    new[6][termios.VTIME] = 3
    termios.tcsetattr(fd, termios.TCSANOW, new)


def _restore_terminal(fd: int, old: list) -> None:
    try:
        termios.tcsetattr(fd, termios.TCSANOW, old)
    except (NameError, Exception):
        pass


def _read_osc_response(fd: int) -> bytes:
    buf = b""
    while True:
        r, _, _ = select.select([fd], [], [], 0.3)
        if not r:
            break
        try:
            ch = os.read(fd, 1)
        except OSError:
            break
        if not ch:
            break
        buf += ch
        if buf.endswith(b"\x1b\\") or buf.endswith(b"\x07"):
            break
    return buf


def _parse_osc11_response(data: bytes) -> tuple[int, int, int] | None:
    text = data.decode(errors="replace")
    m = re.search(
        r"rgb:([0-9a-fA-F]{1,4})/([0-9a-fA-F]{1,4})/([0-9a-fA-F]{1,4})", text
    )
    if m:
        shift_r = max(len(m.group(1)) - 2, 0) * 4
        shift_g = max(len(m.group(2)) - 2, 0) * 4
        shift_b = max(len(m.group(3)) - 2, 0) * 4
        return (
            int(m.group(1), 16) >> shift_r,
            int(m.group(2), 16) >> shift_g,
            int(m.group(3), 16) >> shift_b,
        )
    m = re.search(r"#([0-9a-fA-F]{2})([0-9a-fA-F]{2})([0-9a-fA-F]{2})", text)
    if m:
        return int(m.group(1), 16), int(m.group(2), 16), int(m.group(3), 16)
    return None


# ---------------------------------------------------------------------------
#  Colour scheme
# ---------------------------------------------------------------------------

@dataclass(frozen=True)
class ColorScheme:
    """Base (unblended) colours for the three TLV fields.

    Blending against the terminal background is deferred to render time
    via :func:`_resolve_alpha`, which uses :func:`detect_terminal_background`
    (cached — OSC 11 is queried at most once).
    """

    tag:    AlphaColor
    length: AlphaColor
    value:  AlphaColor

    @classmethod
    def default(cls) -> ColorScheme:
        return cls(
            tag    = AlphaColor(255, 0,   0,   0.2),
            length = AlphaColor(255, 255, 0,   0.2),
            value  = AlphaColor(0,   0,   255, 0.2),
        )


# ---------------------------------------------------------------------------
#  Character display colour
# ---------------------------------------------------------------------------

def char_color(byte: int) -> Color:
    """ANSI colour for the visual representation of a single byte."""
    if 32 <= byte <= 126:
        return AnsiColor(32)   # green — printable ASCII
    if byte in (9, 10, 13):
        return AnsiColor(33)   # yellow — whitespace
    if byte == 0:
        return AnsiColor(37)   # white — NUL
    if byte == 255:
        return AnsiColor(34)   # blue — 0xFF
    return AnsiColor(31)       # red — other control chars


# ---------------------------------------------------------------------------
#  ANSI escape generators
# ---------------------------------------------------------------------------

@cache
def _resolve_alpha(c: AlphaColor) -> TrueColor:
    """Blend *c* against the (cached) terminal background, returning RGB."""
    bg = detect_terminal_background()
    return TrueColor(
        int(c.a * c.r + (1 - c.a) * bg[0]),
        int(c.a * c.g + (1 - c.a) * bg[1]),
        int(c.a * c.b + (1 - c.a) * bg[2]),
    )


def bg_escape(c: Color) -> str:
    match c:
        case None:
            return "\033[49m"
        case TrueColor(r=r, g=g, b=b):
            return f"\033[48;2;{r};{g};{b}m"
        case AlphaColor() as ac:
            rgb = _resolve_alpha(ac)
            return f"\033[48;2;{rgb.r};{rgb.g};{rgb.b}m"
        case AnsiColor(code=code):
            return f"\033[{code + 10}m"
        case _:
            return "\033[49m"


def fg_escape(c: Color) -> str:
    match c:
        case None:
            return "\033[39m"
        case TrueColor(r=r, g=g, b=b):
            return f"\033[38;2;{r};{g};{b}m"
        case AnsiColor(code=code):
            return f"\033[{code}m"
        case _:
            return "\033[39m"


# ---------------------------------------------------------------------------
#  TLV model
# ---------------------------------------------------------------------------

@dataclass(frozen=True)
class TLV:
    """A parsed TLV structure, storing byte-offset boundaries."""

    offset:    int
    tag_end:   int
    len_end:   int
    value_end: int

    def __len__(self) -> int:
        return self.value_end - self.offset

    @property
    def tag_range(self) -> range:
        return range(self.offset, self.tag_end)

    @property
    def length_range(self) -> range:
        return range(self.tag_end, self.len_end)

    @property
    def value_range(self) -> range:
        return range(self.len_end, self.value_end)


# ---------------------------------------------------------------------------
#  Parsing
# ---------------------------------------------------------------------------

def parse(data: bytes, mode: str = "overlap") -> list[TLV]:
    """Scan *data* for TLV structures.

    Parameters
    ----------
    mode:
        ``"overlap"`` – report every candidate (overlapping TLVs are possible).
        ``"exclude"`` – after a match, skip past its value before resuming.
    """
    total = len(data)
    tlvs: list[TLV] = []
    pos = 0

    while pos < total - 1:
        b0, b1 = data[pos], data[pos + 1]
        if _is_tag(b0, b1) and pos + 4 <= total:
            length = data[pos + 2] | (data[pos + 3] << 8)
            if pos + 4 + length <= total:
                tlv = TLV(pos, pos + 2, pos + 4, pos + 4 + length)
                tlvs.append(tlv)
                if mode == "exclude":
                    pos = tlv.value_end
                    continue
        pos += 1

    return tlvs


def _is_tag(b0: int, b1: int) -> bool:
    return 0x00 <= b0 <= TAG_B0_HI and b1 in TAG_B1_SET


# ---------------------------------------------------------------------------
#  TLV summary
# ---------------------------------------------------------------------------

def tlv_info(tlvs: list[TLV], data: bytes) -> str:
    """Return a human-readable summary of each parsed TLV."""
    if not tlvs:
        return ""
    lines: list[str] = []
    for i, tlv in enumerate(tlvs):
        b0 = data[tlv.offset]
        b1 = data[tlv.offset + 1]
        length = data[tlv.tag_end] | (data[tlv.tag_end + 1] << 8)
        tag_str = f"{b0},{chr(b1)!r}"
        lines.append(f"{i}:  offset={tlv.offset:#06x}  TAG: {tag_str}  LEN: {length}")
    return "\n".join(lines)


# ---------------------------------------------------------------------------
#  Render palette — bundles all colour decisions for one render pass
# ---------------------------------------------------------------------------

@dataclass
class RenderPalette:
    """Per-field background colours and a foreground colour function.

    When every field is ``None`` the render path naturally produces plain text.
    """

    tag_bg:  Color = None
    len_bg:  Color = None
    val_bg:  Color = None
    char_fg: Callable[[int], Color] | None = None


# ---------------------------------------------------------------------------
#  xxd rendering
# ---------------------------------------------------------------------------

def render_xxd(data: bytes, tlvs: list[TLV], palette: RenderPalette) -> str:
    """Produce an xxd-style hex dump with ANSI-coloured backgrounds."""
    cmap = _build_cmap_from_tlvs(tlvs, palette)
    char_fg = palette.char_fg
    lines: list[str] = []
    for offset in range(0, len(data), BYTES_PER_LINE):
        chunk = data[offset:offset + BYTES_PER_LINE]
        lines.append(_render_line(offset, chunk, cmap, char_fg))
    return "\n".join(lines)


def _build_cmap_from_tlvs(tlvs: list[TLV],
                          palette: RenderPalette) -> dict[int, Color]:
    cmap: dict[int, Color] = {}
    for tlv in tlvs:
        for p in tlv.tag_range:
            cmap[p] = palette.tag_bg
        for p in tlv.length_range:
            cmap[p] = palette.len_bg
        for p in tlv.value_range:
            cmap[p] = palette.val_bg
    return cmap


def _render_line(offset: int, chunk: bytes, cmap: dict[int, Color],
                 char_fg: Callable[[int], Color] | None) -> str:
    n = len(chunk)

    hex_cells = [
        _hex_cell(offset + j, chunk[j], cmap, char_fg) if j < n else "  "
        for j in range(BYTES_PER_LINE)
    ]
    ascii_cells = [
        _ascii_cell(offset + j, chunk[j], cmap, char_fg) if j < n else " "
        for j in range(BYTES_PER_LINE)
    ]

    left  = " ".join(hex_cells[:HALF_LINE])
    right = " ".join(hex_cells[HALF_LINE:])
    hex_line = f"{left}  {right}"
    ascii_line = "".join(ascii_cells)

    return f"{offset:08x}: {hex_line}{RESET}  {ascii_line}{RESET}"


def _hex_cell(offset: int, byte: int, cmap: dict[int, Color],
              char_fg: Callable[[int], Color] | None) -> str:
    bg = cmap.get(offset)
    fg = char_fg(byte) if char_fg else None
    return f"{RESET}{bg_escape(bg)}{fg_escape(fg)}{byte:02x}"


def _ascii_cell(offset: int, byte: int, cmap: dict[int, Color],
                char_fg: Callable[[int], Color] | None) -> str:
    bg = cmap.get(offset)
    fg = char_fg(byte) if char_fg else None
    ch = chr(byte) if 0x20 <= byte <= 0x7E else "."
    return f"{RESET}{bg_escape(bg)}{fg_escape(fg)}{ch}"


# ---------------------------------------------------------------------------
#  CLI entry point
# ---------------------------------------------------------------------------

def main() -> None:
    ap = argparse.ArgumentParser(
        description="TLV heuristic parser — hex dump / value extraction"
    )

    def _add_mode_arg(p: argparse.ArgumentParser) -> None:
        p.add_argument(
            "-m", "--mode",
            choices=["overlap", "exclude"],
            default="exclude",
            help="Parse mode: exclude (default) or overlap",
        )

    def _add_print_args(p: argparse.ArgumentParser) -> None:
        _add_mode_arg(p)
        p.add_argument(
            "-c", "--color",
            choices=[m.value for m in ColorMode],
            default=ColorMode.ALL.value,
            help="Colouring: all (default), fg/ bg/ none",
        )
        p.add_argument(
            "--show-info",
            action=argparse.BooleanOptionalAction,
            default=True,
            help="Print TLV summary after the hex dump (default: true)",
        )

    _add_print_args(ap)
    sub = ap.add_subparsers(dest="subcmd")

    p_print = sub.add_parser("print", help="Render xxd-style hex dump (default)")
    _add_print_args(p_print)

    p_dump = sub.add_parser("dump", help="Extract raw value bytes of a TLV")
    _add_mode_arg(p_dump)
    p_dump.add_argument("index", type=int, help="TLV index (0-based)")

    args = ap.parse_args()

    data = sys.stdin.buffer.read()
    if not data:
        return

    if args.subcmd == "dump":
        _cmd_dump(args, data)
    else:
        _cmd_print(args, data)


def _cmd_print(args: argparse.Namespace, data: bytes) -> None:
    color_mode = ColorMode(args.color)
    tlvs = parse(data, mode=args.mode)

    if color_mode.use_bg:
        scheme = ColorScheme.default()
        palette = RenderPalette(
            tag_bg  = scheme.tag,
            len_bg  = scheme.length,
            val_bg  = scheme.value,
            char_fg = char_color if color_mode.use_fg else None,
        )
    else:
        palette = RenderPalette(
            char_fg = char_color if color_mode.use_fg else None,
        )

    print(render_xxd(data, tlvs, palette))
    if args.show_info:
        info = tlv_info(tlvs, data)
        if info:
            print(info)


def _cmd_dump(args: argparse.Namespace, data: bytes) -> None:
    tlvs = parse(data, mode=args.mode)
    if not tlvs:
        print("No TLVs found", file=sys.stderr)
        sys.exit(1)
    if args.index < 0 or args.index >= len(tlvs):
        print(f"TLV index {args.index} out of range (0–{len(tlvs) - 1})",
              file=sys.stderr)
        sys.exit(1)
    tlv = tlvs[args.index]
    value = data[tlv.len_end:tlv.value_end]
    sys.stdout.buffer.write(value)


if __name__ == "__main__":
    main()
